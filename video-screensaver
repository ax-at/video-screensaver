start_screensaver() {
    if [[ -n "$SCREENSAVER_PID" ]]; then
        log "WARN" "Screensaver already running (PID: $SCREENSAVER_PID)"
        return 1
    fi
    
    # Disable GNOME shortcuts to prevent window switching, overview, etc.
    disable_gnome_shortcuts
    
    # Create input.conf with ONLY the exit key binding
    # All other keys are explicitly ignored
    cat > "$TEMP_INPUT_CONF" << EOF
# Only allow the exit key combination, ignore everything else
$EXIT_KEY_COMBO quit

# Disable all mouse input
MOUSE_BTN0 ignore
MOUSE_BTN1 ignore
MOUSE_BTN2 ignore
MOUSE_BTN3 ignore
MOUSE_BTN4 ignore
MOUSE_BTN5 ignore
MOUSE_BTN6 ignore
WHEEL_UP ignore
WHEEL_DOWN ignore
WHEEL_LEFT ignore
WHEEL_RIGHT ignore

# Disable common keyboard shortcuts (playback/navigation)
q ignore
ESC ignore
SPACE ignore
ENTER ignore
p ignore
s ignore
f ignore
m ignore
o ignore
i ignore
j ignore
l ignore
k ignore
. ignore
, ignore

# Disable function keys (F1-F12)
F1 ignore
F2 ignore
F3 ignore
F4 ignore
F5 ignore
F6 ignore
F7 ignore
F8 ignore
F9 ignore
F10 ignore
F11 ignore
F12 ignore

# Disable virtual desktop switching (Ctrl+Alt+Left/Right)
Ctrl+Alt+Left ignore
Ctrl+Alt+Right ignore
Ctrl+Alt+Up ignore
Ctrl+Alt+Down ignore

# Disable Alt-Tab and related
Alt+Tab ignore
Ctrl+Alt+Tab ignore

# Disable window management
Super_L ignore
Super_R ignore
Alt ignore

# Disable numeric keypad
KP0 ignore
KP1 ignore
KP2 ignore
KP3 ignore
KP4 ignore
KP5 ignore
KP6 ignore
KP7 ignore
KP8 ignore
KP9 ignore
KP_Decimal ignore
KP_Add ignore
KP_Subtract ignore
KP_Multiply ignore
KP_Divide ignore

# Disable arrow keys
Up ignore
Down ignore
Left ignore
Right ignore

# Disable common modifiers + combinations
Ctrl+q ignore
Ctrl+w ignore
Ctrl+a ignore
Ctrl+s ignore
Ctrl+z ignore
Alt+F4 ignore

# Disable media keys
XF86AudioPlay ignore
XF86AudioPause ignore
XF86AudioNext ignore
XF86AudioPrev ignore
XF86AudioMute ignore
XF86AudioRaiseVolume ignore
XF86AudioLowerVolume ignore

# Disable other common keys
Home ignore
End ignore
Page_Up ignore
Page_Down ignore
Delete ignore
Insert ignore
Backspace ignore
Print ignore
Pause ignore
EOF
    
    log "INFO" "Starting screensaver: mpv $VIDEO_PATH"
    
    # Start mpv with flags to keep it on top
    (
        mpv "$VIDEO_PATH" \
            --loop=inf \
            --fullscreen \
            --no-border \
            --hwdec=no \
            --osc=no \
            --no-osd-bar \
            --cursor-autohide=always \
            --input-conf="$TEMP_INPUT_CONF" \
            --no-input-default-bindings \
            --input-vo-keyboard=no \
            --no-input-cursor \
            --ontop \
            --keep-open=no \
            --window-maximized=yes \
            --force-window=immediate &
        
        local mpv_pid=$!
        
        # Give mpv a moment to create the window
        sleep 1
        
        # Use wmctrl to force window properties if available
        if command -v wmctrl &>/dev/null; then
            # Make window always-on-top and sticky (visible on all desktops)
            wmctrl -r "mpv" -b add,above,sticky 2>/dev/null || true
        fi
        
        # Use xdotool if available to prevent window from losing focus
        if command -v xdotool &>/dev/null; then
            # Focus the mpv window to prevent Alt+Tab from switching away
            xdotool search --name "mpv" windowactivate 2>/dev/null || true
        fi
        
        # Wait for mpv to finish
        wait "$mpv_pid"
    ) &>/dev/null &
    
    SCREENSAVER_PID=$!
    log "INFO" "Screensaver started (PID: $SCREENSAVER_PID)"
}

stop_screensaver() {
    if [[ -z "$SCREENSAVER_PID" ]]; then
        # Still restore shortcuts even if no PID (safety)
        restore_gnome_shortcuts
        return 0
    fi
    
    if kill -0 "$SCREENSAVER_PID" 2>/dev/null; then
        log "INFO" "Stopping screensaver (PID: $SCREENSAVER_PID)"
        kill "$SCREENSAVER_PID" 2>/dev/null || true
        wait "$SCREENSAVER_PID" 2>/dev/null || true
    fi
    
    SCREENSAVER_PID=""
    
    if [[ -n "$INHIBIT_COOKIE" ]]; then
        uninhibit_screensaver "$INHIBIT_COOKIE"
        INHIBIT_COOKIE=""
    fi
    
    rm -f "$TEMP_INPUT_CONF"
    
    # Restore GNOME shortcuts
    restore_gnome_shortcuts
}

cleanup() {
    log "INFO" "Cleaning up..."
    stop_screensaver
    # Double-check shortcuts are restored (safety measure)
    restore_gnome_shortcuts 2>/dev/null || true
    exit 0
}

main_loop() {
    local idle_timeout_ms=$((IDLE_TIMEOUT_MINUTES * 60 * 1000))
    local crash_backoff_ms=30000
    local backoff_until=0
    
    log "INFO" "Video Screensaver Daemon starting..."
    
    while true; do
        local now
        now=$(date +%s%N | head -c 13)
        
        if (( now < backoff_until )); then
            log "DEBUG" "In backoff period, waiting..."
            sleep 5
            continue
        fi
        backoff_until=0
        
        local idle_ms
        idle_ms=$(get_idle_time)
        
        log "DEBUG" "Idle time: ${idle_ms}ms"
        
        if (( idle_ms >= idle_timeout_ms )) && [[ -z "$SCREENSAVER_PID" ]]; then
            log "INFO" "Idle threshold reached, launching screensaver..."
            
            INHIBIT_COOKIE=$(inhibit_screensaver || echo "")
            
            if ! start_screensaver; then
                log "ERROR" "Failed to launch screensaver"
            fi
        fi
        
        if [[ -n "$SCREENSAVER_PID" ]]; then
            # Only stop if mpv process has exited (user pressed exit key)
            # Do NOT stop on general activity - screensaver is locked!
            if ! kill -0 "$SCREENSAVER_PID" 2>/dev/null; then
                log "INFO" "Screensaver process exited (user pressed exit key)"
                stop_screensaver
                backoff_until=$((now + crash_backoff_ms))
            fi
        fi
        
        sleep 1
    done
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --video)
                VIDEO_PATH="$2"
                shift 2
                ;;
            --exit-key)
                EXIT_KEY_COMBO="$2"
                shift 2
                ;;
            --idle-timeout)
                IDLE_TIMEOUT_MINUTES="$2"
                shift 2
                ;;
            --now|--test)
                TEST_MODE=true
                shift
                ;;
            -h|--help)
                echo "Usage: $0 [OPTIONS]"
                echo ""
                echo "Options:"
                echo "  --video <path>           Path to video file (overrides config)"
                echo "  --exit-key <combo>       Exit key combination (overrides config)"
                echo "  --idle-timeout <minutes> Idle timeout in minutes (overrides config)"
                echo "  --now, --test            Start screensaver immediately (no daemon loop)"
                echo "  -h, --help               Show this help message"
                echo ""
                echo "Without --now/--test, runs as a daemon monitoring idle time."
                echo "With --now/--test, immediately starts the screensaver for testing."
                exit 0
                ;;
            *)
                echo "Unknown option: $1" >&2
                echo "Usage: $0 [--video <path>] [--exit-key <combo>] [--idle-timeout <minutes>] [--now|--test]" >&2
                echo "Use --help for more information" >&2
                exit 1
                ;;
        esac
    done
}

trap cleanup SIGTERM SIGINT

parse_args "$@"

if ! load_config; then
    if [[ -z "$VIDEO_PATH" ]]; then
        log "ERROR" "Failed to load configuration and no --video argument provided"
        exit 1
    fi
fi

if [[ -z "$VIDEO_PATH" ]]; then
    log "ERROR" "VIDEO_PATH not set (neither in config nor via --video argument)"
    exit 1
fi

if [[ ! -f "$VIDEO_PATH" ]]; then
    log "ERROR" "Video file not found: $VIDEO_PATH"
    exit 1
fi

mkdir -p "$(dirname "$LOG_FILE")"
log "INFO" "=== Video Screensaver starting ==="
log "INFO" "Config: idle_timeout=${IDLE_TIMEOUT_MINUTES}min, exit_key=$EXIT_KEY_COMBO, video=$VIDEO_PATH"

if [[ "$TEST_MODE" == true ]]; then
    log "INFO" "Test mode: Starting screensaver immediately"
    echo "Starting screensaver in test mode..."
    echo "Video: $VIDEO_PATH"
    echo "Exit key: $EXIT_KEY_COMBO"
    echo ""
    echo "Press $EXIT_KEY_COMBO to exit the screensaver"
    echo ""
    
    INHIBIT_COOKIE=$(inhibit_screensaver || echo "")
    
    if start_screensaver; then
        # Wait for mpv to exit
        wait "$SCREENSAVER_PID" 2>/dev/null || true
        log "INFO" "Screensaver exited"
    else
        log "ERROR" "Failed to start screensaver"
        exit 1
    fi
    
    # Clean up
    stop_screensaver
    log "INFO" "Test mode complete"
else
    main_loop
fi
