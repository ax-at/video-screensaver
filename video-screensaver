#!/bin/bash

set -euo pipefail

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/video-screensaver/config.conf"
readonly TEMP_INPUT_CONF="/tmp/video-screensaver-input.conf"
readonly LOG_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/video-screensaver.log"

IDLE_TIMEOUT_MINUTES=5
EXIT_KEY_COMBO="Ctrl+Alt+c"
VIDEO_PATH=""

SCREENSAVER_PID=""
INHIBIT_COOKIE=""
TEST_MODE=false

log() {
    local level="$1"
    shift
    local message="$*"
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] [$level] $message" >> "$LOG_FILE"
    if [[ "$level" == "ERROR" ]]; then
        echo "[$timestamp] [$level] $message" >&2
    fi
}

get_idle_time() {
    local output
    output=$(busctl call --user org.gnome.Mutter.IdleMonitor \
        /org/gnome/Mutter/IdleMonitor/Core \
        org.gnome.Mutter.IdleMonitor GetIdletime 2>/dev/null || echo "")
    
    if [[ -z "$output" ]]; then
        log "DEBUG" "Failed to get idle time"
        echo "0"
        return 1
    fi
    
    echo "$output" | awk '{print $NF}'
}

inhibit_screensaver() {
    local output
    output=$(busctl call --user org.freedesktop.ScreenSaver \
        /org/freedesktop/ScreenSaver org.freedesktop.ScreenSaver \
        Inhibit ss "video-screensaver" "Video playing" 2>/dev/null || echo "")
    
    if [[ -z "$output" ]]; then
        log "WARN" "Failed to inhibit screensaver"
        return 1
    fi
    
    local cookie
    cookie=$(echo "$output" | awk '{print $NF}')
    log "INFO" "Inhibited screensaver with cookie: $cookie"
    echo "$cookie"
}

uninhibit_screensaver() {
    local cookie="$1"
    
    if [[ -z "$cookie" ]]; then
        return 0
    fi
    
    busctl call --user org.freedesktop.ScreenSaver \
        /org/freedesktop/ScreenSaver org.freedesktop.ScreenSaver \
        UnInhibit u "$cookie" 2>/dev/null || true
    
    log "INFO" "Uninhibited screensaver"
}

load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        log "DEBUG" "Config file not found at $CONFIG_FILE (using defaults or CLI args)"
        return 0
    fi
    
    source "$CONFIG_FILE"
    log "DEBUG" "Config loaded from $CONFIG_FILE"
}

